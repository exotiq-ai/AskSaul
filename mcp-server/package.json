{
  "name": "@asksaul/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server that lets Saul (Claude agent) manage AskSaul proposals: list, review, draft quotes, send via Resend, and sync to GHL.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "asksaul-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@supabase/supabase-js": "^2.45.0",
    "marked": "^14.1.0",
    "resend": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
