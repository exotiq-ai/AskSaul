# AskSaul proposal builder v2 — environment variables
# Copy to .env.local for dev. Netlify env for prod.

# ─── Supabase ─────────────────────────────────────────────────────────────
# Project → Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Never ship the service_role key to the client. Server-only.

# ─── Resend ───────────────────────────────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=

# Sender identity (env-driven so we can flip from gmail → branded domain later)
RESEND_FROM_EMAIL=saul3000bot@gmail.com
RESEND_FROM_NAME="Saul"
# Internal notification recipient (where new lead emails land)
INTERNAL_NOTIFICATION_EMAIL=saul3000bot@gmail.com

# ─── GoHighLevel ──────────────────────────────────────────────────────────
# Legacy webhook (fallback for Phase 1-5)
GHL_WEBHOOK_URL=

# Phase 6 upgrade: GHL v2 API (keep alongside webhook for dual-write during cutover)
GHL_API_KEY=
GHL_LOCATION_ID=

# ─── Admin + MCP ──────────────────────────────────────────────────────────
# Shared secret used by the MCP server (separate package) and any cron endpoints
ADMIN_API_SECRET=
# Basic-auth password for /admin (protect the approval UI)
ADMIN_PASSWORD=

# ─── Site URL ─────────────────────────────────────────────────────────────
# Used in email links
NEXT_PUBLIC_SITE_URL=https://asksaul.ai

# ─── ElevenLabs voice agent (Wolf's Tailor) ───────────────────────────────
# Conversational AI API key. Get from elevenlabs.io → Settings → API Keys.
ELEVENLABS_API_KEY=
# Populated by provision-agent MCP tool after first run.
ELEVENLABS_AGENT_ID=
# Default voice — Jessica. Override per-client if needed.
ELEVENLABS_VOICE_ID=cgSgspJ2msm6clMCkdW9
# HMAC secret for the post-call webhook. Generate: openssl rand -hex 32
ELEVENLABS_WEBHOOK_SECRET=
# Shared secret the agent sends in x-voice-tool-secret header. Generate: openssl rand -hex 32
VOICE_TOOL_SHARED_SECRET=
