# AskSaul.ai production/runtime configuration

# Required for production lead capture.
# Preferred: direct LeadConnector API into the Ask Saul location.
# Do not commit real secrets.
GHL_API_KEY=
GHL_LOCATION_ID=RxCVQeGoQ3RTJbbLG5gY
GHL_API_VERSION=2021-07-28

# Fallback only: an approved Ask Saul / GoHighLevel workflow webhook or proxy endpoint.
# If direct API credentials are present, the app uses direct API and ignores this.
GHL_WEBHOOK_URL=

# Public site URL used by docs, sitemap, and future integrations.
NEXT_PUBLIC_SITE_URL=https://asksaul.ai

# Public demo / booking values. Keep in sync with the voice-agent page.
ASKSAUL_DEMO_PHONE=(970) 401-7285
ASKSAUL_BOOKING_URL=https://api.leadconnectorhq.com/widget/bookings/bookwithusdigitalmarketing-3d837e4b-c899-44ff-b612-275f498c2128

# Current chat mode. If OPENAI_API_KEY or OPENROUTER_API_KEY is present, /api/chat/respond uses live LLM responses with safe fallback copy.
ASKSAUL_CHAT_MODEL=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional production analytics destination. ConversionTracker also pushes events to dataLayer/gtag/plausible when available.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=

# Optional SendBlue transactional thank-you SMS after successful GHL lead capture.
SENDBLUE_API_KEY_ID=
SENDBLUE_API_SECRET_KEY=
SENDBLUE_FROM_NUMBER=
SENDBLUE_OUTBOUND_DRY_RUN=1

# Optional internal alerts after GHL capture succeeds. Webhook wins if set;
# otherwise Telegram bot env is used. Alerts never block lead capture.
ASKSAUL_INTERNAL_ALERT_WEBHOOK_URL=
ASKSAUL_TELEGRAM_BOT_TOKEN=
ASKSAUL_TELEGRAM_CHAT_ID=
ASKSAUL_TELEGRAM_THREAD_ID=
